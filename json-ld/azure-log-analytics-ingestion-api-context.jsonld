{
  "@context": {
    "@version": 1.1,
    "azure": "https://learn.microsoft.com/en-us/azure/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "LogEntry": "azure:LogEntry",
    "DataCollectionRule": "azure:DataCollectionRule",
    "StreamDeclaration": "azure:StreamDeclaration",

    "TimeGenerated": {
      "@id": "azure:time_generated",
      "@type": "xsd:dateTime"
    },
    "Computer": {
      "@id": "azure:computer",
      "@type": "xsd:string"
    },
    "AdditionalContext": {
      "@id": "azure:additional_context",
      "@type": "xsd:string"
    },
    "location": {
      "@id": "azure:location",
      "@type": "xsd:string"
    },
    "kind": {
      "@id": "azure:kind",
      "@type": "xsd:string"
    },
    "workspaceResourceId": {
      "@id": "azure:workspace_resource_id",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "azure:type",
      "@type": "xsd:string"
    },
    "transformKql": {
      "@id": "azure:transform_kql",
      "@type": "xsd:string"
    },
    "outputStream": {
      "@id": "azure:output_stream",
      "@type": "xsd:string"
    }
  }
}
